// Tutorial 4 — Conditions: IF / ELSEIF / ELSE / END IF
//
// BASCAL supports multi-line block IF statements.  The compiler lowers
// them to numeric goto targets so the generated BASIC is compatible with
// 1980s BASCOM.  You never write line numbers yourself.
//
// Forms:
//   if cond then ... end if
//   if cond then ... else ... end if
//   if cond then ... elseif cond then ... else ... end if

/* Simple IF */
temperature% = 23
if temperature% > 30 then
    print "Hot day"
end if

/* IF / ELSE */
score% = 72
if score% >= 60 then
    print "Pass (" + str$(score%) + ")"
else
    print "Fail (" + str$(score%) + ")"
end if

/* IF / ELSEIF / ELSE — grade classification */
points% = 85

if points% >= 90 then
    grade$ = "A"
elseif points% >= 80 then
    grade$ = "B"        // points% = 85 lands here
elseif points% >= 70 then
    grade$ = "C"
elseif points% >= 60 then
    grade$ = "D"
else
    grade$ = "F"
end if

print "Grade: " + grade$

/* Nested IF */
x% = 15
if x% > 0 then
    if x% > 10 then
        print str$(x%) + " is large and positive"
    else
        print str$(x%) + " is small and positive"
    end if
else
    print str$(x%) + " is not positive"
end if

/* Compound conditions */
age%    = 25
income% = 45000
if age% >= 18 and income% >= 30000 then
    print "Eligible"
else
    print "Not eligible"
end if

end
